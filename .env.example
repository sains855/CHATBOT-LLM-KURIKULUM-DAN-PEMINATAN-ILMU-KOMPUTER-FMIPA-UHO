# =====================================================================
# CONFIGURATION ENVIRONMENT VARIABLES - CHATBOT PEMINATAN ILMU KOMPUTER UHO
# =====================================================================
# PENTING: Jangan gunakan spasi di sekitar tanda sama dengan (=)

# 1. Google Gemini API Credentials
# --- Key Utama (wajib ada) ---
GEMINI_API_KEY=your_google_gemini_api_key_here
# --- Key Cadangan (opsional, tambahkan sebanyak yang Anda punya) ---
# Jika key utama kena rate limit 429, sistem otomatis beralih ke key berikutnya
GEMINI_API_KEY_2=your_google_gemini_api_key_2_here
GEMINI_API_KEY_3=your_google_gemini_api_key_3_here
GEMINI_API_KEY_4=your_google_gemini_api_key_4_here
GEMINI_API_KEY_5=your_google_gemini_api_key_5_here
GEMINI_API_KEY_6=your_google_gemini_api_key_6_here
GEMINI_API_KEY_7=your_google_gemini_api_key_7_here
# 2. Database Configuration (MySQL)
DB_HOST=127.0.0.1
DB_USER=root
DB_PASSWORD=password_baru
DB_NAME=uho_rag
DB_PORT=3306

# 3. Flask Server Configuration
FLASK_ENV=development
FLASK_APP=app.py
FLASK_RUN_PORT=5000
